{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/AlexenderSokolov/moonflowgraph/main/docs/run-snapshot-v1.schema.json",
  "title": "MoonFlowGraph Run Snapshot v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "order", "batches", "tasks", "dependencies", "trace"],
  "properties": {
    "schema_version": { "const": 1 },
    "order": {
      "type": "array",
      "items": { "type": "string" }
    },
    "batches": {
      "type": "array",
      "items": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "description",
          "status",
          "status_kind",
          "status_reason",
          "inputs",
          "outputs",
          "tags"
        ],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string" },
          "status_kind": {
            "enum": ["pending", "ready", "running", "succeeded", "failed", "skipped"]
          },
          "status_reason": { "type": ["string", "null"] },
          "inputs": { "type": "array", "items": { "type": "string" } },
          "outputs": { "type": "array", "items": { "type": "string" } },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["before", "after"],
        "properties": {
          "before": { "type": "string" },
          "after": { "type": "string" }
        }
      }
    },
    "trace": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["task_id", "event_type", "timestamp", "message"],
        "properties": {
          "task_id": { "type": "string" },
          "event_type": {
            "enum": ["planned", "started", "completed", "failed", "skipped", "note"]
          },
          "timestamp": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  }
}
